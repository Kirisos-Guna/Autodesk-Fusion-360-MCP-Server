# Copy this file to .env and fill in your values.
# The .env file is git-ignored and must never be committed.

# Host/port where the Fusion 360 add-in HTTP server listens
FUSION_HOST=127.0.0.1
FUSION_PORT=5000

# Shared secret between the MCP server and the Fusion add-in.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FUSION_API_KEY=replace_with_a_strong_random_secret

# Full base URL (optional — overrides HOST+PORT above)
# FUSION_BASE_URL=http://127.0.0.1:5000

# Request timeout in seconds (default 35)
# FUSION_REQUEST_TIMEOUT=35
